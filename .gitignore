node_modules/
packages/*/coverage/
packages/*/dist/
packages/*/node_modules/
apps/*/coverage/
apps/*/dist/
apps/*/node_modules/
apps/*/*.tsbuildinfo
.env.sentry
.env.*.local
.dev.vars
**/.dev.vars
**/.dev.vars.*

# Scratch files that look like they could hold secrets (FRIDGE rule 2).
# Catches common slip-ups: secret.md, secret01.md, secrets_inventory.md, etc.
secret*.md
SECRET*.md
secrets*.md
SECRETS*.md
*.secret
*.secrets
_external_reviews/
# Track standing orders for each external repo but not the repo code itself
!_external_reviews/*/CLAUDE.md

package-lock.json
!apps/supervisor/package-lock.json
!apps/browser-agent/package-lock.json
!packages/browser/package-lock.json

# Storybook
storybook-static

# Video render artifacts (output goes to R2, not git)
apps/video-studio/*.mp4
apps/video-studio/*.webm

# Python bytecode
__pycache__/
*.pyc

# Claude/Copilot agent worktrees (nested git repos — must not be tracked)
.claude/worktrees/
.claude/scheduled_tasks.lock
.claude/settings.local.json

# Provisioning scratch — repo root only, so agent API dumps don't leak into commits.
# This catches the common Cloudflare/GitHub/GCP API curl-output filenames produced
# during one-shot provisioning runs. Subdirectory files with these names are still tracked.
/wrangler.toml
/pages-*.json
/zone*.json
/response*.json
/actions_*.json
/blocked_*.json
/shot.json
/download.log
/generate-jwt.*
