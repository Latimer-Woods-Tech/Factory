# Music/media assets belong in R2, not git
selfprime_music/
*.mp3

node_modules/
packages/*/coverage/
packages/*/dist/
packages/*/node_modules/
apps/*/coverage/
apps/*/dist/
apps/*/node_modules/
apps/*/*.tsbuildinfo
.env.sentry
.env.*.local
.dev.vars
**/.dev.vars
**/.dev.vars.*

# Scratch files that look like they could hold secrets (FRIDGE rule 2).
# Catches common slip-ups: secret.md, secret01.md, secrets_inventory.md, etc.
secret*.md
SECRET*.md
secrets*.md
SECRETS*.md
*.secret
*.secrets
_external_reviews/
# Track standing orders for each external repo but not the repo code itself
!_external_reviews/*/CLAUDE.md

package-lock.json
!apps/supervisor/package-lock.json
!apps/browser-agent/package-lock.json
!apps/qa-tools-worker/package-lock.json
!apps/qa-tools-ui/package-lock.json
!packages/browser/package-lock.json
!packages/bodygraph/package-lock.json
!apps/factory-cross-repo/package-lock.json

# Documentation control-plane run artifacts. Durable generated views under
# docs/_catalog and docs/_generated are tracked separately.
docs-quality-report.json
docs/_catalog/docs-health.json
docs/_catalog/docs-health-summary.md
docs/_catalog/freshness.json
docs/_catalog/freshness.md
docs/_catalog/metadata.json

# Storybook
storybook-static

# Video render artifacts (output goes to R2, not git)
apps/video-studio/*.mp4
apps/video-studio/*.webm

# Generated topology artifact
apps/latwoodtech-web/src/data/circuit-topology.json

# Python bytecode
__pycache__/
*.pyc

# Claude/Copilot agent worktrees (nested git repos — must not be tracked)
.claude/worktrees/
.claude/scheduled_tasks.lock
.claude/settings.local.json

# MCP server configs (often contain plaintext API keys from local setup)
.mcp.json
