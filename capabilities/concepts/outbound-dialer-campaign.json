{
  "schemaVersion": "1.0.0",
  "kind": "concept",
  "id": "outbound-dialer-campaign",
  "displayName": "Outbound Dialer Campaign",
  "owner": "latimer-woods-tech",
  "maturity": "beta",
  "status": "approved",
  "summary": "Governed outbound dialer setup with routing for CRM segment or CSV import audiences.",
  "tags": [
    "telephony",
    "crm",
    "campaigns"
  ],
  "sourcePrimitives": [
    "analytics",
    "compliance",
    "crm",
    "telephony"
  ],
  "recipeCandidates": [
    "outbound-dialer",
    "outbound-dialer-importer"
  ],
  "parameterSchema": {
    "properties": {
      "workerDomain": {
        "type": "string",
        "description": "Custom domain for the deployed worker.",
        "formatHint": "dialer.example.com"
      },
      "campaignSource": {
        "type": "string",
        "description": "Audience source for the campaign.",
        "enum": [
          "crm-segment",
          "csv-import"
        ],
        "default": "crm-segment"
      },
      "enableVoiceSynthesis": {
        "type": "boolean",
        "description": "Enable synthesized voice prompts.",
        "default": true
      }
    },
    "required": [
      "workerDomain",
      "campaignSource"
    ]
  },
  "recipeSelection": {
    "defaultRecipeId": "outbound-dialer",
    "rules": [
      {
        "id": "csv-import-uses-importer",
        "recipeId": "outbound-dialer-importer",
        "matchAll": [
          {
            "parameter": "campaignSource",
            "equals": "csv-import"
          }
        ]
      }
    ]
  },
  "templates": [
    {
      "id": "crm-segment-default",
      "label": "CRM Segment — standard",
      "hint": "Targets a CRM segment with voice synthesis enabled.",
      "values": {
        "campaignSource": "crm-segment",
        "enableVoiceSynthesis": true
      }
    },
    {
      "id": "csv-import-default",
      "label": "CSV Import — batch",
      "hint": "Targets a CSV-imported contact list, no voice synthesis.",
      "values": {
        "campaignSource": "csv-import",
        "enableVoiceSynthesis": false
      }
    }
  ],
  "qualification": {
    "menuVisible": true,
    "approvalTier": "council-reviewed",
    "requiredCapabilities": [
      "custom-domain"
    ],
    "disallowedEnvironments": [
      "local"
    ]
  }
}
