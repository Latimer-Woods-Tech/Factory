{
  "schemaVersion": "1.0.0",
  "kind": "plan",
  "recipe": {
    "id": "outbound-dialer",
    "version": "0.1.0",
    "maturity": "experimental",
    "summary": "Outbound call-bank service pattern for compliant campaign dialing and disposition capture.",
    "goal": "Provision a staging-first outbound calling service with lead targeting, consent-aware controls, and delivery telemetry."
  },
  "packages": [
    {
      "primitiveId": "analytics",
      "package": "@latimer-woods-tech/analytics",
      "versionRange": "^0.2.0"
    },
    {
      "primitiveId": "compliance",
      "package": "@latimer-woods-tech/compliance",
      "versionRange": "^0.3.0"
    },
    {
      "primitiveId": "crm",
      "package": "@latimer-woods-tech/crm",
      "versionRange": "^0.3.0"
    },
    {
      "primitiveId": "telephony",
      "package": "@latimer-woods-tech/telephony",
      "versionRange": "^0.3.0"
    }
  ],
  "env": {
    "secrets": [
      "AI_GATEWAY_BASE_URL",
      "ANTHROPIC_API_KEY",
      "DEEPGRAM_API_KEY",
      "ELEVENLABS_API_KEY",
      "GROQ_API_KEY",
      "JWT_SECRET",
      "POSTHOG_KEY",
      "TELNYX_API_KEY",
      "VERTEX_ACCESS_TOKEN",
      "VERTEX_LOCATION",
      "VERTEX_PROJECT"
    ],
    "vars": [
      "ENVIRONMENT",
      "WORKER_NAME"
    ],
    "policyTags": [
      "audit",
      "communications",
      "compliance",
      "customer-data",
      "observability",
      "outbound-communications",
      "outbound-sensitive",
      "pii",
      "telemetry",
      "voice"
    ]
  },
  "bindings": {
    "required": [
      "AUTH_RATE_LIMITER",
      "DB",
      "FLAG_TELEMETRY",
      "FLAGS"
    ],
    "optional": []
  },
  "expectedSurfaces": [
    "/health",
    "/manifest",
    "/api/campaigns",
    "/api/campaigns/:id/start",
    "/api/dispositions"
  ],
  "smokeChecks": [
    {
      "path": "/health",
      "expectedStatus": 200,
      "expectContains": "status"
    },
    {
      "path": "/manifest",
      "expectedStatus": 200,
      "expectContains": "manifestVersion"
    }
  ],
  "constraints": [
    "Outbound dialing must not be provisioned without compliance and consent-aware auditability.",
    "Provisioning is staging-first; no direct production bootstrap path is supported.",
    "Generated service must expose /health and /manifest before promotion is allowed."
  ],
  "scaffold": {
    "entryScript": "packages/deploy/scripts/scaffold.mjs",
    "stagingFirst": true,
    "requiredSecrets": [
      "JWT_SECRET"
    ],
    "requiredBindings": [
      "AUTH_RATE_LIMITER",
      "DB",
      "FLAG_TELEMETRY",
      "FLAGS"
    ],
    "requiredVars": [
      "ENVIRONMENT",
      "WORKER_NAME"
    ]
  }
}
