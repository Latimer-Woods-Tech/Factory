{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "concept.schema.json",
  "title": "Capability Concept",
  "description": "Operator-facing concept that maps approved parameters to one or more recipes.",
  "type": "object",
  "required": [
    "id",
    "displayName",
    "summary",
    "status",
    "maturity",
    "tags",
    "menuVisible",
    "approvalTier",
    "parameters",
    "recipes",
    "sourcePrimitives",
    "qualification"
  ],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
    "displayName": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["draft", "proposed", "approved", "deprecated"] },
    "maturity": { "type": "string", "enum": ["draft", "experimental", "beta", "stable", "deprecated", "retired"] },
    "tags": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "menuVisible": { "type": "boolean" },
    "approvalTier": { "type": "string", "enum": ["golden", "supported", "experimental"] },
    "parameters": {
      "type": "array",
      "items": { "$ref": "#/definitions/parameter" }
    },
    "recipeSelection": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["defaultRecipeId"],
          "additionalProperties": false,
          "properties": {
            "defaultRecipeId": { "type": "string" },
            "rules": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["id", "recipeId", "matchAll"],
                "additionalProperties": false,
                "properties": {
                  "id": { "type": "string", "minLength": 1 },
                  "recipeId": { "type": "string", "minLength": 1 },
                  "matchAll": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "type": "object",
                      "required": ["parameter", "equals"],
                      "additionalProperties": false,
                      "properties": {
                        "parameter": { "type": "string" },
                        "equals": {
                          "type": ["string", "number", "boolean"]
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      ]
    },
    "recipes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "summary", "maturity", "primitives", "optionalPrimitives"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "summary": { "type": "string" },
          "maturity": { "type": "string" },
          "primitives": { "type": "array", "items": { "type": "string" } },
          "optionalPrimitives": { "type": "array", "items": { "type": "string" } },
          "tradeoffs": { "type": "string" }
        }
      }
    },
    "sourcePrimitives": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "templates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label", "hint", "values"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
          "label": { "type": "string", "minLength": 1 },
          "hint": { "type": "string", "minLength": 1 },
          "values": {
            "type": "object",
            "additionalProperties": { "type": ["string", "number", "boolean"] }
          }
        }
      }
    },
    "qualification": {
      "type": "object",
      "required": ["menuVisible", "approvalTier"],
      "additionalProperties": false,
      "properties": {
        "menuVisible": { "type": "boolean" },
        "approvalTier": { "type": "string" },
        "requiredCapabilities": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "disallowedEnvironments": {
          "type": "array",
          "items": { "type": "string", "enum": ["local", "staging", "production"] },
          "uniqueItems": true
        }
      }
    }
  },
  "definitions": {
    "parameter": {
      "type": "object",
      "required": ["id", "type", "description", "required", "enum", "default", "formatHint"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-zA-Z][a-zA-Z0-9]*$" },
        "type": { "type": "string", "enum": ["string", "boolean", "integer", "number"] },
        "description": { "type": "string", "minLength": 1 },
        "required": { "type": "boolean" },
        "enum": {
          "type": "array",
          "items": { "type": ["string", "number", "boolean"] }
        },
        "default": { "type": ["string", "number", "boolean", "null"] },
        "formatHint": { "type": ["string", "null"] }
      }
    }
  }
}
