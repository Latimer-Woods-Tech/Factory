{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "rule.schema.json",
  "title": "Capability Rule Bundle",
  "description": "Rules enforcing compatibility constraints between primitives within a recipe.",
  "type": "object",
  "required": ["rules"],
  "additionalProperties": false,
  "properties": {
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
          "ifAllPrimitives": {
            "type": "array",
            "items": { "type": "string" },
            "uniqueItems": true
          },
          "thenRequirePrimitives": {
            "type": "array",
            "items": { "type": "string" },
            "uniqueItems": true
          }
        }
      }
    }
  }
}
