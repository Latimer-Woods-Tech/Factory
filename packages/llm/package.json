{
  "name": "@latimer-woods-tech/llm",
  "version": "0.4.4",
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Latimer-Woods-Tech/Factory.git",
    "directory": "packages/llm"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "test": "vitest run --coverage",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "prepublish": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@latimer-woods-tech/errors": "^0.2.0",
    "@latimer-woods-tech/logger": "^0.2.0"
  },
  "devDependencies": {
    "@latimer-woods-tech/monitoring": "^0.2.0",
    "@types/node": "^25.6.0",
    "typescript": "^5.4.0",
    "tsup": "^8.1.0",
    "vitest": "^4.1.8",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0"
  }
}
