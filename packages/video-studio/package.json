{
  "name": "@latimer-woods-tech/video-studio",
  "version": "0.1.0",
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Latimer-Woods-Tech/Factory.git",
    "directory": "packages/video-studio"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --external react --external remotion --external zod",
    "test": "vitest run --coverage",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "prepublish": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@latimer-woods-tech/bodygraph": "file:../bodygraph",
    "@latimer-woods-tech/video": "file:../video"
  },
  "peerDependencies": {
    "@remotion/bundler": ">=4",
    "@remotion/renderer": ">=4",
    "react": ">=18",
    "remotion": ">=4",
    "zod": ">=3"
  },
  "peerDependenciesMeta": {
    "@remotion/bundler": { "optional": true },
    "@remotion/renderer": { "optional": true }
  },
  "devDependencies": {
    "@remotion/bundler": "^4.0.0",
    "@remotion/renderer": "^4.0.0",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^8.57.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "remotion": "^4.0.0",
    "tsup": "^8.1.0",
    "typescript": "^5.4.0",
    "vitest": "^3.2.4",
    "zod": "^3.23.0"
  }
}
