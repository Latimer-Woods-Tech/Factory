{
  "name": "@latimer-woods-tech/design-tokens",
  "version": "0.2.0",
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Latimer-Woods-Tech/Factory.git",
    "directory": "packages/design-tokens"
  },
  "description": "Design system tokens (colors, spacing, typography, motion) for Factory apps",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    },
    "./tokens.css": "./dist/tokens.css",
    "./tailwind-preset": "./dist/tailwind.preset.cjs"
  },
  "files": [
    "dist",
    "tokens",
    "build-tokens.mjs",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts && node build-tokens.mjs",
    "test": "vitest run --coverage",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.4.0",
    "tsup": "^8.1.0",
    "vitest": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "style-dictionary": "^4.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
