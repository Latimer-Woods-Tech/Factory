{
  "font-size": {
    "$type": "dimension",
    "xs": { "$value": "12px" },
    "sm": { "$value": "14px" },
    "base": { "$value": "16px" },
    "lg": { "$value": "18px" },
    "xl": { "$value": "20px" },
    "2xl": { "$value": "24px" },
    "3xl": { "$value": "30px" },
    "4xl": { "$value": "36px" }
  },
  "font-weight": {
    "$type": "fontWeight",
    "light": { "$value": 300 },
    "regular": { "$value": 400 },
    "medium": { "$value": 500 },
    "semibold": { "$value": 600 },
    "bold": { "$value": 700 }
  },
  "line-height": {
    "$type": "number",
    "tight": { "$value": 1.2 },
    "snug": { "$value": 1.375 },
    "normal": { "$value": 1.5 },
    "relaxed": { "$value": 1.625 },
    "loose": { "$value": 2 }
  },
  "letter-spacing": {
    "$type": "dimension",
    "tight": { "$value": "-0.02em" },
    "normal": { "$value": "0em" },
    "wide": { "$value": "0.05em" }
  },
  "font-family": {
    "$type": "fontFamily",
    "sans": { "$value": "-apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Oxygen, Ubuntu, Cantarell, \"Open Sans\", \"Helvetica Neue\", sans-serif" },
    "mono": { "$value": "\"SF Mono\", Monaco, \"Cascadia Code\", \"Roboto Mono\", Consolas, \"Courier New\", monospace" }
  }
}
