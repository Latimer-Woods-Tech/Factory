{
  "duration": {
    "$type": "duration",
    "fastest": { "$value": "75ms" },
    "faster": { "$value": "100ms" },
    "fast": { "$value": "150ms" },
    "normal": { "$value": "300ms" },
    "slow": { "$value": "500ms" },
    "slower": { "$value": "700ms" }
  },
  "easing": {
    "$type": "cubicBezier",
    "linear": { "$value": "linear" },
    "in": { "$value": "cubic-bezier(0.4, 0, 1, 1)" },
    "out": { "$value": "cubic-bezier(0, 0, 0.2, 1)" },
    "in-out": { "$value": "cubic-bezier(0.4, 0, 0.2, 1)" }
  }
}
