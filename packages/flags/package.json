{
  "name": "@latimer-woods-tech/flags",
  "version": "0.1.0",
  "description": "Typed Cloudflare Flagship wrapper with telemetry, naming enforcement, and mock client for the Latimer-Woods-Tech factory platform.",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./testing": {
      "import": "./dist/mock.js",
      "types": "./dist/mock.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/mock.ts --format esm --dts --clean",
    "test": "vitest run",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "prepublish": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "peerDependencies": {
    "typescript": ">=5.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.18",
    "@cloudflare/workers-types": "^4.20260507.1",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "files": [
    "dist"
  ],
  "license": "UNLICENSED",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
