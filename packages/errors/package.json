{
  "name": "@latimer-woods-tech/errors",
  "version": "0.1.0",
  "description": "Typed, retryable-aware error classes and a Hono error-boundary middleware for Cloudflare Workers, Bun, Deno, and Node.",
  "license": "MIT",
  "author": "Adrian Perry <aperry@latwoodtech.com>",
  "homepage": "https://github.com/Latimer-Woods-Tech/Factory/tree/main/packages/errors",
  "bugs": {
    "url": "https://github.com/Latimer-Woods-Tech/Factory/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Latimer-Woods-Tech/Factory.git",
    "directory": "packages/errors"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "errors",
    "typescript",
    "esm",
    "operational-errors",
    "hono",
    "http"
  ],
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "test": "vitest run --coverage",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "hono": "^4.12.18"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.4.0",
    "tsup": "^8.1.0",
    "vitest": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0"
  }
}
