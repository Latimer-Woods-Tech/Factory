# factory CODEOWNERS — path-scoped trust model (MA-4)
# Reference: docs/architecture/FACTORY_V1.md §5.3 + docs/supervisor/FRIDGE.md
# Closes #82
#
# Trust tiers (from docs/supervisor/FRIDGE.md):
#   Green  = docs/**, *.md, session/**            → supervisor can merge on blessed template
#   Yellow = apps/*/src/**, client/**, tests/**   → auto-PR + auto-merge on green CI + plan-approval
#   Red    = everything below (workflows, packages, migrations, billing/admin/stripe handlers, configs)
#
# Any file not matched by a later pattern falls through to the default (`*`).
# Later patterns override earlier ones.

# ===========================================================================
# DEFAULT — Red tier: Adrian reviews unless a later pattern broadens
# ===========================================================================
*                                       @adrper79-dot @factory-cross-repo[bot]
# ===========================================================================
# GREEN tier — supervisor (via factory-cross-repo bot) can merge on blessed template
# @factory-cross-repo[bot] is co-owner so its 2-party-confirmed APPROVE satisfies
# the code-owner gate without human intervention.
# @github-actions[bot] is also co-owner so snapshot-pr-auto-merge.yml can approve
# as github-actions[bot] (REVIEW_TOKEN = github.token) without self-approval
# conflict — factory-cross-repo[bot] opens the PR; github-actions[bot] approves.
# ===========================================================================
docs/**                                 @adrper79-dot @factory-cross-repo[bot] @github-actions[bot]
*.md                                    @adrper79-dot @factory-cross-repo[bot] @github-actions[bot]
session/**                              @adrper79-dot @factory-cross-repo[bot] @github-actions[bot]
documents/**                            @adrper79-dot @factory-cross-repo[bot] @github-actions[bot]
# MA-8: memory single-writer — explicit ownership so the branch-protection review
# gate fires on every memory/*.md edit, enforcing the single-writer invariant.
memory/**                               @adrper79-dot
.github/ISSUE_TEMPLATE/**               @adrper79-dot @factory-cross-repo[bot]
.github/PULL_REQUEST_TEMPLATE.md        @adrper79-dot @factory-cross-repo[bot]

# ===========================================================================
# YELLOW tier — auto-PR + auto-merge on green CI + 2-party LLM approval
# @factory-cross-repo[bot] is co-owner so Grok→Claude consensus APPROVE drives
# merge without requiring @adrper79-dot on every PR.
# ===========================================================================
apps/*/src/**                           @adrper79-dot @factory-cross-repo[bot]
apps/*/src/components/ui/**             @adrper79-dot @factory-cross-repo[bot]
client/**                               @adrper79-dot @factory-cross-repo[bot]
tests/**                                @adrper79-dot @factory-cross-repo[bot]

# ===========================================================================
# RED tier — gated by 2-party LLM review (Grok → Claude consensus)
# @factory-cross-repo[bot] is co-owner; the LLM checkpoint is the final gate.
# Claude has hardcoded guidance to block Actions injection, irreversible
# migrations, billing idempotency violations, and CODEOWNERS self-modification.
# These override any broader Yellow/Green pattern above.
# ===========================================================================

# CI / workflows — any change here multiplies across all apps
.github/workflows/**                    @adrper79-dot @factory-cross-repo[bot]
# Workflow registry is the canonical tier classification — human-only.
# Bot cannot move workflows between tiers; tier changes need a CODEOWNER PR.
# Reference: docs/decisions/2026-05-23-workflow-lifecycle.md (Pillar 1)
.github/workflows/REGISTRY.md           @adrper79-dot
.github/CODEOWNERS                      @adrper79-dot @factory-cross-repo[bot]

# Shared packages — every consumer app is affected on bump
packages/**                             @adrper79-dot @factory-cross-repo[bot]

# DB migrations — unreversible schema changes
workers/src/db/migrations/**            @adrper79-dot @factory-cross-repo[bot]
migrations/**                           @adrper79-dot @factory-cross-repo[bot]

# Billing / admin / Stripe handlers — money path
workers/src/handlers/billing*           @adrper79-dot @factory-cross-repo[bot]
workers/src/handlers/admin*             @adrper79-dot @factory-cross-repo[bot]
workers/src/handlers/stripe*            @adrper79-dot @factory-cross-repo[bot]
apps/*/workers/src/handlers/billing*    @adrper79-dot @factory-cross-repo[bot]
apps/*/workers/src/handlers/admin*      @adrper79-dot @factory-cross-repo[bot]
apps/*/workers/src/handlers/stripe*     @adrper79-dot @factory-cross-repo[bot]

# Deployment config
wrangler.jsonc                          @adrper79-dot @factory-cross-repo[bot]
wrangler.toml                           @adrper79-dot @factory-cross-repo[bot]
apps/*/wrangler.jsonc                   @adrper79-dot @factory-cross-repo[bot]

# Capability declarations and service registry
capabilities.yml                        @adrper79-dot @factory-cross-repo[bot]
apps/*/capabilities.yml                 @adrper79-dot @factory-cross-repo[bot]
docs/service-registry.yml               @adrper79-dot @factory-cross-repo[bot]

# Supervisor internals (once SUP-3.4 scaffold lands)
apps/supervisor/**                      @adrper79-dot @factory-cross-repo[bot]

# Template library — supervisor plans are code that drives autonomous execution
docs/supervisor/plans/**                @adrper79-dot @factory-cross-repo[bot]
docs/supervisor/FRIDGE.md               @adrper79-dot @factory-cross-repo[bot]
