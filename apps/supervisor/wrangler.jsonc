{
  "name": "factory-supervisor",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-01",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": true,

  // Cron: 11:00 UTC = 07:00 AM ET on weekdays (Mon–Fri).
  // Required secrets (injected by deploy-supervisor.yml from GitHub repo secrets):
  //   FACTORY_APP_ID              — GitHub App numeric ID
  //   FACTORY_APP_PRIVATE_KEY     — GitHub App RSA private key PEM
  //   FACTORY_APP_INSTALLATION_ID — GitHub App installation ID for Latimer-Woods-Tech/factory
  //   PUSHOVER_TOKEN              — Pushover application token
  //   PUSHOVER_USER_KEY           — Pushover user/group key
  //   JWT_SECRET                  — Supervisor JWT signing secret
  //   GROQ_API_KEY                — Groq API key for LLM fallback
  "triggers": {
    "crons": ["0 11 * * 1-5"]
  },

  "durable_objects": {
    "bindings": [
      { "name": "SUPERVISOR", "class_name": "SupervisorDO" },
      { "name": "LOCK", "class_name": "LockDO" }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["SupervisorDO", "LockDO"]
    }
  ],

  "d1_databases": [
    {
      "binding": "MEMORY",
      "database_name": "factory-supervisor-memory",
      "database_id": "9463b4a2-06c4-4f6a-b6ac-d6e1cb552bc2"
    },
    {
      "binding": "LLM_LEDGER",
      "database_name": "factory-supervisor-ledger",
      "database_id": "1033b6bf-d38f-4948-8f3b-0de787c87f6b"
    }
  ],

  "vars": {
    "AI_GATEWAY_BASE_URL": "https://gateway.ai.cloudflare.com/v1/a1c8a33cbe8a3c9e260480433a0dbb06/supervisor",
    "VERTEX_PROJECT": "factory-495015",
    "VERTEX_LOCATION": "us-central1",
    "PER_RUN_CAP_CENTS": "500"
  },

  "env": {
    "production": {
      "workers_dev": false,
      "routes": [
        { "pattern": "supervisor.latwoodtech.work/*", "zone_name": "latwoodtech.work" },
        { "pattern": "supervisor.apunlimited.com/*", "zone_name": "apunlimited.com" }
      ]
    }
  }
}
