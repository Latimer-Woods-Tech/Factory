{
  "name": "factory-supervisor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "generate:templates": "node ../../scripts/generate-supervisor-templates.mjs",
    "generate:capabilities": "node ../../scripts/generate-supervisor-capabilities.mjs",
    "prebuild": "npm run generate:templates && npm run generate:capabilities",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --env production",
    "deploy:staging": "wrangler deploy --env staging",
    "test": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@latimer-woods-tech/admin": "^0.2.0",
    "@latimer-woods-tech/agent": "^0.1.0",
    "@latimer-woods-tech/errors": "^0.2.0",
    "@latimer-woods-tech/llm": "^0.5.0",
    "@latimer-woods-tech/llm-meter": "^0.2.4",
    "@latimer-woods-tech/logger": "^0.2.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240925.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "js-yaml": "^4.1.1",
    "typescript": "^5.4.0",
    "vitest": "^4.1.5",
    "wrangler": "^4.103.0"
  }
}
