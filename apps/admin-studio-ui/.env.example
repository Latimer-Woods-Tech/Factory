# admin-studio-ui environment configuration
# Copy this file to .env.local for local development.
# Never commit .env.local — it is listed in .gitignore.
#
# Worker mounts routes at /auth, /synthetic, /ai, etc. — no /api prefix on the worker side.
# So these base URLs must NOT end with /api.

# Local development — points at the admin-studio Worker running via `wrangler dev`.
VITE_API_BASE_LOCAL=http://localhost:8787

# Staging backend — canonical URL from docs/service-registry.yml (id: admin-studio-staging).
VITE_API_BASE_STAGING=https://admin-staging.latwoodtech.work

# Production backend — canonical URL from docs/service-registry.yml (id: admin-studio-production).
VITE_API_BASE_PROD=https://api.apunlimited.com

# Legacy single-env var still read by AiTab.tsx and TestsTab.tsx (env-blind).
# Point at production by default; remove once both files migrate to getApiBase().
VITE_API_BASE=https://api.apunlimited.com
