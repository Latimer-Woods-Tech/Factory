# admin-studio-ui environment configuration
# Copy this file to .env.local for local development.
# Never commit .env.local — it is listed in .gitignore.

# Default API base used when neither _LOCAL, _STAGING, nor _PROD is needed
# (e.g. for a single-target deploy or Vite dev proxy fallback).
VITE_API_BASE=/api

# Local development — points at the admin-studio Worker running via `wrangler dev`.
VITE_API_BASE_LOCAL=http://localhost:8787/api

# Staging backend — canonical URL from docs/service-registry.yml (id: admin-studio-staging).
VITE_API_BASE_STAGING=https://admin-studio-staging.adrper79.workers.dev/api

# Production backend — canonical URL from docs/service-registry.yml (id: admin-studio-production).
VITE_API_BASE_PROD=https://admin-studio-production.adrper79.workers.dev/api
