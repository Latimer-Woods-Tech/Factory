{
  "name": "@latimer-woods-tech/browser-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Dockerized Playwright Browser Agent for GCP Cloud Run",
  "type": "module",
  "scripts": {
    "build": "tsup src/index.ts src/server.ts --format esm --dts",
    "start": "node dist/server.js",
    "test": "vitest run --coverage",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.1",
    "@aws-sdk/client-s3": "^3.757.0",
    "@hono/node-server": "^1.19.13",
    "axe-core": "^4.11.4",
    "hono": "^4.12.21",
    "playwright": "^1.60.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^8.57.0",
    "tsup": "^8.5.0",
    "typescript": "^5.4.5",
    "vitest": "^3.2.4"
  }
}
