{
  "name": "linkedin-publisher",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-01",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": true,

  // Cron: Tue/Thu at 14:00 UTC  →  "0 14 * * 2,4"
  "triggers": {
    "crons": ["0 14 * * 2,4"]
  },

  "vars": {
    "ENVIRONMENT": "development",
    // AI Gateway endpoint for this worker
    "AI_GATEWAY_BASE_URL": "https://gateway.ai.cloudflare.com/v1/a1c8a33cbe8a3c9e260480433a0dbb06/linkedin-publisher",
    "VERTEX_PROJECT": "factory-495015",
    "VERTEX_LOCATION": "us-central1"
  },

  "env": {
    "production": {
      "workers_dev": false,
      "vars": {
        "ENVIRONMENT": "production",
        "AI_GATEWAY_BASE_URL": "https://gateway.ai.cloudflare.com/v1/a1c8a33cbe8a3c9e260480433a0dbb06/linkedin-publisher",
        "VERTEX_PROJECT": "factory-495015",
        "VERTEX_LOCATION": "us-central1"
      }
    }
  }
}

