{
  "name": "lead-gen",
  "main": "src/index.ts",
  "compatibility_date": "2024-05-16",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "vars": {
    "ENVIRONMENT": "production"
  },
  "queues": {
    "producers": [
      {
        "binding": "LEAD_GEN_QUEUE",
        "queue": "factory-lead-gen-queue"
      }
    ]
  }
}