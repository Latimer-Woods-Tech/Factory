{
  "name": "video-cron",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-01",
  "hyperdrive": [
    {
      "binding": "DB",
      "id": "78e47571fffb4a81ba12ee454507e006"
    }
  ],
  // Cron disabled: video production now runs on the billing-proof Cloud Run Job
  // `render-runner` (driven by GCP Cloud Scheduler) instead of dispatching to
  // the billing-locked GitHub Actions. Having both drain schedule-worker's queue
  // races/double-renders, so this dispatcher is paused. Re-add ["0 * * * *"] to
  // revert once GitHub billing is restored. See tools/render-runner/README.md.
  "triggers": {
    "crons": []
  },
  "flagship": { "binding": "FLAGS" },
  "d1_databases": [
    { "binding": "FLAG_TELEMETRY", "database_id": "f03af37d-11d9-4428-b0db-b3cdca8fe7c4", "database_name": "flag-meter" }
  ],
  "services": [
    {
      "binding": "SCHEDULE_WORKER",
      "service": "schedule-worker"
    }
  ],
  "vars": {
    "APP_ID": "selfprime",
    "DEFAULT_COMPOSITION_ID": "EnergyBlueprintVideo",
    "ENVIRONMENT": "development",
    "GITHUB_REPO": "Latimer-Woods-Tech/factory",
    "SCHEDULE_WORKER_URL": "https://schedule.latwoodtech.work"
  },
  "env": {
    "production": {
      "name": "video-cron",
      "hyperdrive": [
        {
          "binding": "DB",
          "id": "78e47571fffb4a81ba12ee454507e006"
        }
      ],
      // Disabled — superseded by the Cloud Run `render-runner` job (see above).
      "triggers": {
        "crons": []
      },
      "services": [
        {
          "binding": "SCHEDULE_WORKER",
          "service": "schedule-worker"
        }
      ],
      "vars": {
        "APP_ID": "selfprime",
        "DEFAULT_COMPOSITION_ID": "EnergyBlueprintVideo",
        "ENVIRONMENT": "production",
        "GITHUB_REPO": "Latimer-Woods-Tech/factory",
        "SCHEDULE_WORKER_URL": "https://schedule.latwoodtech.work"
      }
    }
  }
}

