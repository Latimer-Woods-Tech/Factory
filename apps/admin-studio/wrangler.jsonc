{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "admin-studio",
  "main": "src/index.ts",
  "compatibility_date": "2025-01-01",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "vars": {
    "STUDIO_ENV": "staging",
    "STUDIO_GOOGLE_WORKSPACE_DOMAIN": "latwoodtech.com",
    "ALLOWED_ORIGINS": "https://studio.thefactory.dev,https://apunlimited.com,https://staging.admin-studio-ui.pages.dev"
  },
  "env": {
    "staging": {
      "name": "admin-studio-staging",
      "routes": [
        { "pattern": "admin-staging.latwoodtech.work", "custom_domain": true }
      ],
      "vars": {
        "STUDIO_ENV": "staging",
        "STUDIO_GOOGLE_WORKSPACE_DOMAIN": "latwoodtech.com",
        "ALLOWED_ORIGINS": "https://staging.admin-studio-ui.pages.dev,https://admin-staging.latwoodtech.work,http://localhost:5173",
        // Digest non-secret vars
        "DIGEST_TO_EMAIL": "adrper79@gmail.com",
        "ELEVENLABS_VOICE_DEFAULT": "21m00Tcm4TlvDq8ikWAM",
        "SENTRY_ORG": "latwood-tech",
        "R2_PUBLIC_DOMAIN": "https://digest-assets.thefactory.dev"
        // Secrets (wrangler secret put --env staging):
        //   FACTORY_APP_ID, FACTORY_APP_PRIVATE_KEY, FACTORY_APP_INSTALLATION_ID
        //   ELEVENLABS_API_KEY, RESEND_API_KEY, SUPERVISOR_URL (optional)
      },
      "hyperdrive": [
        {
          "binding": "DB",
          "id": "efe957f404bb457593e6bd08b733b7c4"
        },
        {
          // THE_FACTORY core database (factory-core-db Hyperdrive)
          // Points to Neon Factory database for admin queries
          "binding": "FACTORY_DB",
          "id": "efe957f404bb457593e6bd08b733b7c4"
        }
      ],
      "kv_namespaces": [
        {
          "binding": "MONITOR_KV",
          "id": "6579dabe32f0444ba29bfb722c1e02b1"
        }
      ],
      "r2_buckets": [
        {
          // Create bucket first: wrangler r2 bucket create factory-digest-audio
          "binding": "DIGEST_R2",
          "bucket_name": "factory-digest-audio"
        }
      ],
      "services": [
        {
          "binding": "SCHEDULE_WORKER",
          "service": "schedule-worker"
        }
      ],
      "triggers": {
        "crons": [
          "0 */6 * * *",
          // Digest: 06:30 ET (10:30 UTC) and 18:30 ET (22:30 UTC)
          "30 10 * * *",
          "30 22 * * *"
        ]
      }
    },
    "production": {
      "name": "admin-studio-production",
      "vars": {
        "STUDIO_ENV": "production",
        "STUDIO_GOOGLE_WORKSPACE_DOMAIN": "latwoodtech.com",
        "ALLOWED_ORIGINS": "https://studio.thefactory.dev,https://apunlimited.com",
        // Digest non-secret vars
        "DIGEST_TO_EMAIL": "adrper79@gmail.com",
        "ELEVENLABS_VOICE_DEFAULT": "21m00Tcm4TlvDq8ikWAM",
        "SENTRY_ORG": "latwood-tech",
        "R2_PUBLIC_DOMAIN": "https://digest-assets.thefactory.dev"
        // Secrets (wrangler secret put --env production):
        //   FACTORY_APP_ID, FACTORY_APP_PRIVATE_KEY, FACTORY_APP_INSTALLATION_ID
        //   ELEVENLABS_API_KEY, RESEND_API_KEY, SUPERVISOR_URL (optional)
      },
      "hyperdrive": [
        {
          "binding": "DB",
          "id": "efe957f404bb457593e6bd08b733b7c4"
        },
        {
          "binding": "FACTORY_DB",
          "id": "efe957f404bb457593e6bd08b733b7c4"
        }
      ],
      "kv_namespaces": [
        {
          "binding": "MONITOR_KV",
          "id": "6579dabe32f0444ba29bfb722c1e02b1"
        }
      ],
      "r2_buckets": [
        {
          "binding": "DIGEST_R2",
          "bucket_name": "factory-digest-audio"
        }
      ],
      "services": [
        {
          "binding": "SCHEDULE_WORKER",
          "service": "schedule-worker"
        }
      ],
      "triggers": {
        "crons": [
          "0 */6 * * *",
          // Digest: 06:30 ET (10:30 UTC) and 18:30 ET (22:30 UTC)
          "30 10 * * *",
          "30 22 * * *"
        ]
      }
    }
  },
  "d1_databases": [
    { "binding": "FLAG_TELEMETRY", "database_id": "f03af37d-11d9-4428-b0db-b3cdca8fe7c4", "database_name": "flag-meter" }
  ],
  "observability": {
    "enabled": true
  }
}
