{
  "extends": "../../tsconfig.internal-packages.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "ESNext", "WebWorker"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "types": ["@cloudflare/workers-types"],
    "outDir": "dist",
  },
  "include": ["src/**/*", "tests/**/*"]
}
